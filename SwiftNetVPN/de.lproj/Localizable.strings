/* Infoseiten */
"about_title" = "Über die App";
"about_version" = "Version";
"about_intro" = "SwiftNet ist eine einfache und zuverlässige VPN‑App. Mit einem Tipp wird dein Datenverkehr durch einen sicheren Tunnel verschlüsselt.\n\nWir legen Wert auf einfache Bedienung und minimale Datenerfassung. Deine Verbindung ist geschützt; wir protokollieren weder deinen Browserverlauf noch persönliche Daten.\n\nVielen Dank, dass du uns gewählt hast. Weitere Informationen und Updates findest du auf unserer offiziellen Website.";
"about_website" = "Offizielle Website";
"guide_title" = "Nutzung";
"guide_content" = "1. Tippe auf die Haupttaste, um zu verbinden; tippe erneut, um zu trennen.\n2. Tippe auf „Aktueller Server“, um einen anderen Knoten zu wählen.\n3. Wenn du verbunden bist, wird dein Datenverkehr durch einen verschlüsselten Tunnel geleitet.";
"privacy_policy_title" = "Datenschutzrichtlinie";
"privacy_policy_content" = "Wir verwenden VPN, um einen verschlüsselten Tunnel zu erstellen. Wir sammeln keine direkt personenbezogenen Daten. Verbindungsprotokolle werden nur zur Verbesserung des Dienstes verwendet.";
